# ============================================================================
#  データ取得スクリプト（scripts/update.mjs）用の環境変数
#  このファイルを .env にコピーして使います。 ※ .env はコミットしない（.gitignore 済み）
# ============================================================================

# 使用するデータ提供元:
#   espn          … 無料・APIキー不要（推奨）。ESPN の公開JSONから WC2026 を取得
#   football-data … football-data.org（要・無料キー。WC2026 の無料枠カバレッジは要確認）
#   api-football  … api-sports.io（無料プランは2026シーズン非対応。有料プランが必要）
FOOTBALL_API_PROVIDER=espn

# APIキー。espn では不要（空のままでOK）。football-data / api-football では必須。
FOOTBALL_API_KEY=

# ---- 任意（通常は変更不要）----------------------------------------------

# [espn] 取得対象リーグと大会期間（日付レンジ）
# FOOTBALL_ESPN_LEAGUE=fifa.world
# FOOTBALL_ESPN_DATES=20260611-20260719

# [api-football] WC2026 のリーグID・シーズン
# FOOTBALL_LEAGUE_ID=1
# FOOTBALL_SEASON=2026

# [football-data] 大会コード
# FOOTBALL_COMPETITION=WC

# ベースURLの上書き（モック時など）
# FOOTBALL_API_BASE=
