# ============================================================================
#  データ取得スクリプト（scripts/update.mjs）用の環境変数
#  このファイルを .env にコピーして値を埋めてください。
#  ※ .env は絶対にコミットしない（.gitignore 済み）
# ============================================================================

# 使用するデータ提供元: "api-football" もしくは "football-data"
FOOTBALL_API_PROVIDER=api-football

# API キー（プロバイダのダッシュボードで取得）
FOOTBALL_API_KEY=

# ---- 任意（通常は変更不要）----------------------------------------------

# [api-football] WC2026 のリーグID・シーズン。既定: league=1, season=2026
# FOOTBALL_LEAGUE_ID=1
# FOOTBALL_SEASON=2026

# [football-data] 大会コード。既定: WC
# FOOTBALL_COMPETITION=WC

# ベースURLの上書き（RapidApi 経由やモック時のみ）
# FOOTBALL_API_BASE=
